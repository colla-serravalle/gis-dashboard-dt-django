# =============================================================================
# Django Core
# =============================================================================
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=generate-a-64-char-random-string-here
DEBUG=False
ALLOWED_HOSTS=your-domain.example.com
DJANGO_ADMIN_URL=app-control-panel/

# =============================================================================
# PostgreSQL — used by both the db container and Django
# =============================================================================
# Container vars (postgres image reads these)
POSTGRES_DB=reports_db
POSTGRES_USER=reports_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Django DB vars (must match POSTGRES_* above; DB_HOST=db = Docker service name)
DB_NAME=reports_db
DB_USER=reports_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=db
DB_PORT=5432

# =============================================================================
# Redis
# =============================================================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CACHE_BACKEND=redis

# =============================================================================
# Logging — all three log files written to app-logs volume (/app/logs/)
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Azure AD / OIDC
# =============================================================================
AZURE_TENANT_ID=your-azure-tenant-uuid
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# =============================================================================
# ArcGIS
# =============================================================================
ARCGIS_PORTAL_TOKEN_URL=https://gisserver.serravalle.it/portal/sharing/rest/generateToken
ARCGIS_FEATURE_SERVICE_URL=https://gisserver.serravalle.it/server/rest/services/Hosted/service_bfa0d5450bcd491bb1732edc3ce173ad/FeatureServer
ARCGIS_PORTAL_BASE_URL=https://gisserver.serravalle.it/portal
ARCGIS_USERNAME=your-arcgis-username
ARCGIS_PASSWORD=your-arcgis-password
ARCGIS_REFERER=https://reports.serravalle.it/
ARCGIS_TOKEN_EXPIRATION_MINUTES=60

# =============================================================================
# Security
# =============================================================================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
LOGIN_TRUSTED_PROXIES=172.20.0.0/16
SESSION_TIMEOUT=3600
CSRF_TRUSTED_ORIGINS=https://reports.serravalle.it