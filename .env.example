# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ArcGIS Configuration
ARCGIS_PORTAL_TOKEN_URL=https://gisserver.serravalle.it/portal/sharing/rest/generateToken
ARCGIS_FEATURE_SERVICE_URL=https://gisserver.serravalle.it/server/rest/services/Hosted/service_bfa0d5450bcd491bb1732edc3ce173ad/FeatureServer
ARCGIS_USERNAME=your-arcgis-username
ARCGIS_PASSWORD=your-arcgis-password
ARCGIS_REFERER=https://reports.serravalle.it/
ARCGIS_TOKEN_EXPIRATION_MINUTES=60

# Session Settings
SESSION_TIMEOUT=3600

# Pagination
ITEMS_PER_PAGE=10
MAX_ITEMS_PER_PAGE=100

# Azure AD / OIDC Authentication
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Native tls for uvicorn
UV_NATIVE_TLS=true
